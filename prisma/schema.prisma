generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SiteRole {
  ADMIN
  USER
}

enum UserPlan {
  MUSICIEN
  CREATEUR
}

enum GroupRole {
  CHEF
  MEMBRE
}

enum GroupPlan {
  FREE
  PRO
  PREMIUM
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  INCERTAIN
}

enum SongProgressStatus {
  A_TRAVAILLER
  EN_COURS
  MAITRISE
}

enum ResourceType {
  PDF
  AUDIO
  IMAGE
  GRILLE
  LIEN
  AUTRE
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String
  siteRole      SiteRole  @default(USER)
  userPlan      UserPlan  @default(CREATEUR)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  instruments              UserInstrument[]
  groups                   GroupMember[]
  attendances              Attendance[]
  resources                Resource[]
  joinRequests             JoinRequest[]
  groupHistory             GroupMemberHistory[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  songProgress             UserSongProgress[]
  remindersReceived        ReminderLog[]            @relation("RemindedUser")
  remindersSent            ReminderLog[]            @relation("ReminderSender")
}

model Instrument {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users UserInstrument[]
}

model UserInstrument {
  userId       Int
  instrumentId Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@id([userId, instrumentId])
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  isPublic         Boolean   @default(true)
  isHidden         Boolean   @default(false)
  plan             GroupPlan @default(FREE)
  storageUsedBytes BigInt    @default(0)
  lookingFor       String?   @db.Text
  lookingForSince DateTime?
  createdAt       DateTime  @default(now())

  members      GroupMember[]
  rehearsals   Rehearsal[]
  concerts     Concert[]
  songs        Song[]
  setlists     Setlist[]
  joinRequests JoinRequest[]
}

model GroupMember {
  userId    Int
  groupId   Int
  groupRole GroupRole @default(MEMBRE)
  joinedAt  DateTime  @default(now())
  cardOrder String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Rehearsal {
  id        Int      @id @default(autoincrement())
  groupId   Int
  date      DateTime
  location  String
  startTime String
  endTime   String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  group        Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  songs        RehearsalSong[]
  attendances  Attendance[]
  reminderLogs ReminderLog[]
}

model RehearsalSong {
  rehearsalId Int
  songId      Int
  position    Int @default(0)
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  song        Song      @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([rehearsalId, songId])
}

model UserSongProgress {
  userId    Int
  songId    Int
  status    SongProgressStatus @default(A_TRAVAILLER)
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([userId, songId])
}

model Attendance {
  userId      Int
  rehearsalId Int
  status      AttendanceStatus @default(INCERTAIN)
  updatedAt   DateTime         @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)

  @@id([userId, rehearsalId])
}

model Concert {
  id        Int      @id @default(autoincrement())
  groupId   Int
  name      String
  date      DateTime
  location  String
  notes     String?  @db.Text
  setlistId Int?
  createdAt DateTime @default(now())

  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  setlist Setlist? @relation(fields: [setlistId], references: [id], onDelete: SetNull)
}

model Setlist {
  id          Int      @id @default(autoincrement())
  groupId     Int
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group    Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  songs    SetlistSong[]
  concerts Concert[]
}

model SetlistSong {
  setlistId Int
  songId    Int
  position  Int @default(0)

  setlist Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([setlistId, songId])
}

model Song {
  id        Int      @id @default(autoincrement())
  groupId   Int
  title     String
  artist    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  group        Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resources    Resource[]
  rehearsals   RehearsalSong[]
  userProgress UserSongProgress[]
  setlists     SetlistSong[]
}

model GroupMemberHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  groupName String
  leftAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JoinRequest {
  id        Int               @id @default(autoincrement())
  userId    Int
  groupId   Int
  status    JoinRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model SiteSetting {
  key   String @id
  value String
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resource {
  id           Int          @id @default(autoincrement())
  songId       Int
  name         String
  type         ResourceType
  filePath     String
  fileSize     Int?
  uploadedById Int
  createdAt    DateTime     @default(now())

  song       Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model ReminderLog {
  id          Int      @id @default(autoincrement())
  rehearsalId Int
  userId      Int
  sentById    Int
  sentAt      DateTime @default(now())

  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  user      User      @relation("RemindedUser", fields: [userId], references: [id], onDelete: Cascade)
  sentBy    User      @relation("ReminderSender", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([rehearsalId])
  @@index([userId])
}
