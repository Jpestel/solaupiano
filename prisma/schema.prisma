generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SiteRole {
  ADMIN
  USER
}

enum TicketCategory {
  BUG
  QUESTION
  FEATURE
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum UserPlan {
  MUSICIEN
  CREATEUR
}

enum GroupRole {
  CHEF
  MEMBRE
}

// Type d'espace : groupe de musique ou classe / école de musique.
enum GroupType {
  BAND
  SCHOOL
}

model Plan {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  label       String
  description String? @db.Text

  priceMonthly Float?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  storageGb    Float @default(1)

  maxGroups          Int  @default(1)
  maxMembersPerGroup Int?
  maxSongsPerGroup   Int?
  maxSetlists        Int?
  maxConcerts        Int?
  maxCharts          Int?
  maxFilesPerSong    Int?

  hasGrilles         Boolean @default(true)
  hasConcerts        Boolean @default(true)
  hasSetlists        Boolean @default(true)
  hasFicheTechnique  Boolean @default(true)
  hasMaPage          Boolean @default(true)
  hasCoChefs         Boolean @default(true)
  hasPrioritySupport Boolean @default(false)
  hasStats           Boolean @default(false)
  hasFileSubmissions Boolean @default(true)
  hasAnnonces        Boolean @default(false)
  hasMetronome       Boolean @default(true)
  hasParoles         Boolean @default(true)
  hasSequences       Boolean @default(true)
  hasEvaluations     Boolean @default(true)
  hasAccounting      Boolean @default(true)
  hasChat            Boolean @default(true)
  hasSharedResources Boolean @default(true)
  hasUnavailabilities Boolean @default(true)
  hasPolls           Boolean @default(true)
  hasGalerie         Boolean @default(true)
  hasSocial          Boolean @default(true)

  color     String   @default("gray")

  stripePriceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AnnonceStatus {
  PENDING
  ACTIVE
  VENDUE
  EXPIREE
  MASQUEE
}

model AnnonceCategorie {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  label     String
  emoji     String  @default("📌")
  hint      String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  INCERTAIN
  EN_ATTENTE  // n'a pas encore répondu (statut par défaut)
}

enum SongProgressStatus {
  A_TRAVAILLER
  EN_COURS
  MAITRISE
}

enum ResourceType {
  PDF
  AUDIO
  VIDEO
  IMAGE
  GRILLE
  LIEN
  AUTRE
}

enum SequenceKind {
  AUDIO
  MIDI
}

enum SequenceChannelMode {
  STEREO    // lecture stéréo normale
  SPLIT_LR  // canal gauche = click, canal droit = backing (volumes indépendants)
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  name          String
  avatarUrl     String?
  stageFigure   String?   // look du personnage sur le plan de scène (clé : p1, p2, …)
  stageColor    String?   // couleur du personnage sur le plan de scène (hex)
  stageName     String?   // nom de scène affiché sur le plan de scène (sinon : nom)
  siteRole      SiteRole  @default(USER)
  userPlan      UserPlan  @default(CREATEUR)
  accountPlan   String    @default("FREE") // abonnement au niveau du compte (FREE|PRO|PREMIUM), se répercute sur les groupes fondés
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lastLoginAt                 DateTime?
  gusoNumber                  String?
  weeklyDigestOptOut          Boolean   @default(false)
  rehearsalReminderOptOut     Boolean   @default(false)
  evaluationReminderOptOut    Boolean   @default(false)
  concertTimeReminderOptOut   Boolean   @default(false)
  // Compte de test : exclu des compteurs et du site public, isolé dans l'admin.
  // Se répercute sur isTest de tous les groupes fondés par ce compte.
  isTest                      Boolean   @default(false)
  adminLoginAlertEnabled      Boolean   @default(true)  // envoie une alerte admin quand ce compte se connecte
  helpBubblesOptOut           Boolean   @default(false) // masque les bulles d'aide contextuelles

  instruments              UserInstrument[]
  groups                   GroupMember[]
  foundedGroups            Group[]          @relation("GroupFounder")
  attendances              Attendance[]
  resources                Resource[]
  pendingResources         PendingResource[]
  joinRequests             JoinRequest[]
  groupHistory             GroupMemberHistory[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  songProgress             UserSongProgress[]
  assignmentsReceived      Assignment[]            @relation("AssignmentStudent")
  assignmentsGiven         Assignment[]            @relation("AssignmentTeacher")
  remindersReceived        ReminderLog[]            @relation("RemindedUser")
  remindersSent            ReminderLog[]            @relation("ReminderSender")
  autoReminders            RehearsalAutoReminder[]
  annonces                 Annonce[]
  moduleUserOverrides      ModuleUserOverride[]
  groupMessages            GroupMessage[]
  supportTickets           SupportTicket[]
  cachetSimulations        CachetSimulation[]
  gear                     UserGear[]
  sharedResources          GroupSharedResource[]
  songSequences            SongSequence[]
  unavailabilities         Unavailability[]
  flashInfoViews           FlashInfoView[]
  pollVotes                PollVote[]
  evaluationsAuthored      RehearsalEvaluation[]   @relation("EvaluationAuthor")
  ratingsReceived          RehearsalMemberRating[] @relation("MemberRated")
  concertAttendances       ConcertAttendance[]     @relation("ConcertAttendee")
  concertEvaluations       ConcertEvaluation[]     @relation("ConcertEvaluationAuthor")
  concertRatingsReceived   ConcertMemberRating[]   @relation("ConcertMemberRated")
  expensesPaid             GroupExpense[]          @relation("ExpensePaidBy")
  expenseShares            ExpenseShare[]          @relation("ExpenseShareUser")
  galleryPhotos            GalleryPhoto[]          @relation("GalleryUploader")
  moduleVisits             ModuleVisit[]
  sequenceLoops            SequenceLoop[]
  scoreMarkers             ScoreMarker[]
  blogPosts                BlogPost[]              @relation("BlogAuthor")
  blogLikes                BlogLike[]
  socialPosts              SocialPost[]
  helpBubbleDismissals     HelpBubbleDismissal[]
  taskAssignments          TaskAssignee[]
}

// ─── Blog ────────────────────────────────────────────────────────────────────
model BlogCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  color     String   @default("indigo")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  posts BlogPost[]
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String    @db.LongText // HTML
  coverImage  String?
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?
  viewCount   Int       @default(0)
  categoryId  Int?
  authorId    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author   User?         @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  likes    BlogLike[]

  @@index([status, publishedAt])
}

model BlogLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

enum FlashInfoType {
  INFO
  ASTUCE
  NEWS
  ALERTE
}

enum FlashInfoUnit {
  HOUR
  DAY
  WEEK
  MONTH
}

model FlashInfo {
  id            Int           @id @default(autoincrement())
  type          FlashInfoType @default(INFO)
  title         String
  content       String        @db.Text
  ctaLabel      String?       // libellé d'un bouton d'action optionnel
  ctaUrl        String?       // lien du bouton (interne ou externe)
  active        Boolean       @default(true)
  startAt       DateTime?     // début de la fenêtre de diffusion
  endAt         DateTime?     // fin de la fenêtre de diffusion
  recurring     Boolean       @default(false) // false = une seule fois par utilisateur
  intervalValue Int           @default(1)
  intervalUnit  FlashInfoUnit @default(DAY)
  maxDisplays   Int?          // nombre max d'affichages par utilisateur (null = illimité)
  priority      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  views FlashInfoView[]
}

model FlashInfoView {
  id          Int      @id @default(autoincrement())
  flashInfoId Int
  userId      Int
  count       Int      @default(0)
  lastSeenAt  DateTime @default(now())

  flashInfo FlashInfo @relation(fields: [flashInfoId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flashInfoId, userId])
  @@index([userId])
}

model UserGear {
  id        Int      @id @default(autoincrement())
  userId    Int
  category  String   // INSTRUMENT, AMP, MIC, EFFECT, DRUMS, KEYS, CABLE, AUDIO, ACCESSORY, OTHER
  name      String   // ex: "Fender Stratocaster"
  brand     String?  // marque
  details   String?  @db.Text // précisions / specs
  quantity  Int      @default(1)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Instrument {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users UserInstrument[]
}

model UserInstrument {
  userId       Int
  instrumentId Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@id([userId, instrumentId])
}

model Group {
  id          Int       @id @default(autoincrement())
  name        String
  type        GroupType @default(BAND) // groupe de musique ou classe / école
  studentModules String? @db.Text // école : JSON des modules visibles par les élèves (null = défaut)
  description String?   @db.Text
  style       String?  // genre / style musical (null = non renseigné)
  coverUrl         String?
  isPublic         Boolean   @default(true)
  isHidden         Boolean   @default(false)
  // Groupe de test : reflète isTest du fondateur. Exclu des compteurs / du public.
  isTest           Boolean   @default(false)
  plan             String    @default("FREE")
  planExpiresAt    DateTime?
  storageUsedBytes BigInt    @default(0)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  lookingFor       String?   @db.Text
  lookingForSince DateTime?
  createdAt       DateTime  @default(now())
  createdBy        Int?
  chefPermissions  Json?
  maxMembersOverride     Int?
  storageQuotaOverrideGb Int?   // Admin per-group storage override (independent quota)
  peerRatingVisibility   PeerRatingVisibility @default(PRIVATE) // visibilité des notes entre musiciens
  archivedAt             DateTime? // groupe archivé (masqué aux membres, conservé)
  inviteToken      String?   @unique // jeton du lien d'invitation partageable (email/SMS/WhatsApp)
  founder          User?     @relation("GroupFounder", fields: [createdBy], references: [id], onDelete: SetNull)

  members          GroupMember[]
  assignments      Assignment[]
  levelGroups      StudentLevelGroup[]
  rehearsals       Rehearsal[]
  concerts         Concert[]
  songs            Song[]
  setlists         Setlist[]
  chordCharts      ChordChart[]
  joinRequests     JoinRequest[]
  techRider        TechRider?
  groupPage        GroupPage?
  pendingResources PendingResource[]
  moduleGroupOverrides ModuleGroupOverride[]
  messages         GroupMessage[]
  sharedResources  GroupSharedResource[]
  unavailabilities Unavailability[]
  polls            Poll[]
  expenses         GroupExpense[]
  resourceLinkOverrides GroupResourceLink[]
  galleryPhotos    GalleryPhoto[]
  galleryCategories GalleryCategory[]
  socialPosts      SocialPost[]
  taskLists        TaskList[]
}

// Catalogue de liens de ressources (audios, vidéos, tutos, partitions…)
// proposés à l'ajout d'un morceau. Activables/désactivables par groupe.
model ResourceLink {
  id            Int      @id @default(autoincrement())
  label         String
  icon          String   @default("🔗")
  category      String   @default("OTHER") // VIDEO | AUDIO | TUTO | SCORE | TAB | LYRICS | OTHER
  urlTemplate   String   @db.Text          // contient {q} (remplacé par titre+artiste encodé)
  description   String?
  defaultActive Boolean  @default(false)    // actif par défaut pour tous les groupes
  enabled       Boolean  @default(true)     // disponible globalement
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  groupOverrides GroupResourceLink[]
}

// Surcharge par groupe : active = true/false explicite (sinon defaultActive)
model GroupResourceLink {
  groupId        Int
  resourceLinkId Int
  active         Boolean

  group Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  link  ResourceLink @relation(fields: [resourceLinkId], references: [id], onDelete: Cascade)

  @@id([groupId, resourceLinkId])
  @@index([groupId])
}

model GroupExpense {
  id          Int      @id @default(autoincrement())
  groupId     Int
  title       String
  description String?  @db.Text
  amount      Float    // montant total de la dépense
  date        DateTime @db.Date
  period      String?  // libellé de période (ex : "Juin 2026", "Trimestre 1")
  category    String?  // Salle, Matériel, Transport, Autre…
  paidById    Int?     // membre ayant avancé l'argent (null = caisse commune)
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User?          @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  shares ExpenseShare[]

  @@index([groupId])
}

model ExpenseShare {
  id        Int       @id @default(autoincrement())
  expenseId Int
  userId    Int
  amount    Float     // part due par ce membre
  paid      Boolean   @default(false)
  paidAt    DateTime?

  expense GroupExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User         @relation("ExpenseShareUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
}

model Poll {
  id          Int      @id @default(autoincrement())
  groupId     Int
  title       String
  description String?  @db.Text
  createdById Int?
  closed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  group   Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  options PollOption[]

  @@index([groupId])
}

model PollOption {
  id     Int      @id @default(autoincrement())
  pollId Int
  date   DateTime @db.Date
  note   String?
  order  Int      @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        Int              @id @default(autoincrement())
  optionId  Int
  userId    Int
  status    AttendanceStatus @default(INCERTAIN)
  updatedAt DateTime         @updatedAt

  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId])
}

model Unavailability {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([userId])
}

model GroupSharedResource {
  id          Int      @id @default(autoincrement())
  groupId     Int
  type        String   // LINK, SHOP, CONTACT, NOTE, FILE
  title       String
  url         String?  // LINK
  address     String?  // SHOP (adresse physique)
  phone       String?  // CONTACT
  email       String?  // CONTACT
  note        String?  @db.Text // description / contenu libre
  filePath    String?  // FILE
  fileSize    Int?     // FILE (octets)
  createdById Int
  createdAt   DateTime @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model GalleryPhoto {
  id         Int      @id @default(autoincrement())
  groupId    Int
  uploaderId Int
  filePath   String   // chemin public, ex : /uploads/galerie/...
  fileSize   Int      // octets (après compression)
  caption    String?  @db.Text
  eventType  String?  // REHEARSAL | CONCERT | CATEGORY (obligatoire à l'upload)
  eventId    Int?     // id de la répétition / du concert / de la catégorie
  eventLabel String?  // libellé dénormalisé pour l'affichage (album)
  createdAt  DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploader User  @relation("GalleryUploader", fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([groupId, eventType, eventId])
}

// Posts réseaux sociaux composés par le chef/co-chef (texte + images), pour partage.
model SocialPost {
  id        Int      @id @default(autoincrement())
  groupId   Int
  authorId  Int?
  caption   String   @db.Text
  images    String   @db.Text // JSON : tableau d'URLs d'images
  taggedUserIds String? @db.Text // JSON : ids des membres identifiés (ayant consenti au droit à l'image)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([groupId])
}

model GalleryCategory {
  id        Int      @id @default(autoincrement())
  groupId   Int
  name      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
}

// Audit d'usage : une ligne par visite de module/page (résolu en libellé lisible).
model ModuleVisit {
  id          Int      @id @default(autoincrement())
  userId      Int
  path        String   @db.Text
  moduleKey   String
  moduleLabel String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([moduleKey])
  @@index([createdAt])
}

model GroupPage {
  id           Int     @id @default(autoincrement())
  groupId      Int     @unique
  slug         String  @unique
  published    Boolean @default(false)

  primaryColor String  @default("#4f46e5")
  accentColor  String  @default("#7c3aed")
  bgColor      String  @default("#ffffff")
  textColor    String  @default("#111827")

  bannerTitle    String?
  bannerSubtitle String?
  bio            String? @db.LongText
  memberCards    Json    @default("[]")

  showConcerts Boolean @default(true)
  showContact  Boolean @default(true)
  contactTitle String?

  instagram String?
  facebook  String?
  youtube   String?
  spotify   String?
  website   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model TechRider {
  id         Int      @id @default(autoincrement())
  groupId    Int      @unique
  content    Json
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model GroupMember {
  userId    Int
  groupId   Int
  groupRole GroupRole @default(MEMBRE)
  joinedAt  DateTime  @default(now())
  cardOrder String?
  // Consentement à la diffusion du visage (photos/vidéos) sur les réseaux sociaux.
  // null = pas encore répondu, true = accepté, false = refusé.
  imageConsent   Boolean?
  imageConsentAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model Rehearsal {
  id        Int      @id @default(autoincrement())
  groupId   Int
  date      DateTime
  location  String
  startTime String
  endTime   String?
  notes     String?  @db.Text
  setlistId Int?
  createdAt DateTime @default(now())
  photoReminderSentAt DateTime? // mail "partagez vos photos" envoyé 30 min avant

  group        Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  setlist      Setlist?        @relation(fields: [setlistId], references: [id], onDelete: SetNull)
  songs        RehearsalSong[]
  attendances  Attendance[]
  reminderLogs  ReminderLog[]
  autoReminders RehearsalAutoReminder[]
  evaluations  RehearsalEvaluation[]
}

model RehearsalEvaluation {
  id          Int      @id @default(autoincrement())
  rehearsalId Int
  evaluatorId Int
  selfRating  Int      // 1-5 : sa propre performance
  groupRating Int      // 1-5 : performance du groupe
  suggestion  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rehearsal     Rehearsal               @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  evaluator     User                    @relation("EvaluationAuthor", fields: [evaluatorId], references: [id], onDelete: Cascade)
  memberRatings RehearsalMemberRating[]
  songRatings   RehearsalSongRating[]

  @@unique([rehearsalId, evaluatorId])
  @@index([rehearsalId])
}

model EvaluationReminderLog {
  id          Int      @id @default(autoincrement())
  rehearsalId Int
  userId      Int
  sentAt      DateTime @default(now())

  @@unique([rehearsalId, userId])
}

enum PeerRatingVisibility {
  HIDDEN  // notes entre musiciens masquées (personne ne les voit)
  PRIVATE // chacun voit seulement sa propre moyenne reçue (anonyme)
  PUBLIC  // détail nominatif visible par tous
}

model RehearsalSongRating {
  id           Int @id @default(autoincrement())
  evaluationId Int
  songId       Int
  rating       Int // 1-5

  evaluation RehearsalEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  song       Song                @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, songId])
  @@index([songId])
}

model RehearsalMemberRating {
  id           Int @id @default(autoincrement())
  evaluationId Int
  ratedUserId  Int
  rating       Int // 1-5

  evaluation RehearsalEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  ratedUser  User                @relation("MemberRated", fields: [ratedUserId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, ratedUserId])
  @@index([ratedUserId])
}

model RehearsalSong {
  rehearsalId Int
  songId      Int
  position    Int @default(0)
  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  song        Song      @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([rehearsalId, songId])
}

model UserSongProgress {
  userId    Int
  songId    Int
  status    SongProgressStatus @default(A_TRAVAILLER)
  percent   Int                @default(0) // 0..100 : niveau de maîtrise
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([userId, songId])
}

model Attendance {
  userId      Int
  rehearsalId Int
  status      AttendanceStatus @default(EN_ATTENTE)
  updatedAt   DateTime         @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)

  @@id([userId, rehearsalId])
}

model Concert {
  id        Int      @id @default(autoincrement())
  groupId   Int
  name      String
  date      DateTime
  location  String   // salle / nom du lieu
  address    String?  // adresse (rue)
  postalCode String?  // code postal
  city       String?  // ville
  latitude   Float?
  longitude  Float?
  geocodedAddress String? @db.Text
  startTime       String? // heure de début / passage (HH:MM)
  soundcheckTime  String? // heure des balances (HH:MM)
  arrivalTime     String? // arrivée souhaitée (HH:MM)
  arrivalInfo     String? // pour qui / précisions sur l'arrivée
  guestsPerPerson Int?    // nombre d'accompagnants autorisés par musicien
  contactName     String? // contact sur place
  contactPhone    String?
  // Validation du concert : membres devant obligatoirement confirmer leur présence
  requiredUserIds        String?  // JSON : userIds devant obligatoirement être présents
  confirmDaysBefore      Int?     // délai de réponse : X jours avant la date (deadline = date - X)
  status                 String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED
  validationReminderSentAt DateTime?
  // Dernière relance « heure de début manquante » envoyée au(x) chef(s) (cadence récurrente).
  timeReminderSentAt     DateTime?
  cancelledAt            DateTime?
  notes     String?  @db.Text
  setlistId Int?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  group       Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  setlist     Setlist?            @relation(fields: [setlistId], references: [id], onDelete: SetNull)
  stageLayout StageLayout?
  simulations CachetSimulation[]
  attendances ConcertAttendance[]
  evaluations ConcertEvaluation[]
}

model ConcertAttendance {
  userId    Int
  concertId Int
  status    AttendanceStatus @default(EN_ATTENTE)
  updatedAt DateTime         @updatedAt

  user    User    @relation("ConcertAttendee", fields: [userId], references: [id], onDelete: Cascade)
  concert Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)

  @@id([userId, concertId])
  @@index([concertId])
}

model ConcertEvaluation {
  id          Int      @id @default(autoincrement())
  concertId   Int
  evaluatorId Int
  selfRating  Int
  groupRating Int
  suggestion  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  concert       Concert                @relation(fields: [concertId], references: [id], onDelete: Cascade)
  evaluator     User                   @relation("ConcertEvaluationAuthor", fields: [evaluatorId], references: [id], onDelete: Cascade)
  memberRatings ConcertMemberRating[]
  songRatings   ConcertSongRating[]

  @@unique([concertId, evaluatorId])
  @@index([concertId])
}

model ConcertMemberRating {
  id           Int @id @default(autoincrement())
  evaluationId Int
  ratedUserId  Int
  rating       Int

  evaluation ConcertEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  ratedUser  User              @relation("ConcertMemberRated", fields: [ratedUserId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, ratedUserId])
  @@index([ratedUserId])
}

model ConcertSongRating {
  id           Int @id @default(autoincrement())
  evaluationId Int
  songId       Int
  rating       Int

  evaluation ConcertEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  song       Song              @relation("ConcertSongRated", fields: [songId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, songId])
  @@index([songId])
}

model ConcertEvaluationReminderLog {
  id        Int      @id @default(autoincrement())
  concertId Int
  userId    Int
  sentAt    DateTime @default(now())

  @@unique([concertId, userId])
}

model StageLayout {
  id        Int      @id @default(autoincrement())
  concertId Int      @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concert Concert @relation(fields: [concertId], references: [id], onDelete: Cascade)
}

model Setlist {
  id           Int      @id @default(autoincrement())
  groupId      Int
  name         String
  description  String?  @db.Text
  showDuration Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  songs      SetlistSong[]
  concerts   Concert[]
  rehearsals Rehearsal[]
}

model SetlistSong {
  setlistId Int
  songId    Int
  position  Int @default(0)

  setlist Setlist @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  song    Song    @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@id([setlistId, songId])
}

model Song {
  id              Int      @id @default(autoincrement())
  groupId         Int
  title           String
  artist          String?
  notes           String?  @db.Text
  durationSeconds Int?
  tempo           Int?     // BPM
  createdAt       DateTime @default(now())

  group            Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resources        Resource[]
  pendingResources PendingResource[]
  rehearsals       RehearsalSong[]
  userProgress     UserSongProgress[]
  assignments      Assignment[]
  setlists         SetlistSong[]
  chordCharts      ChordChart[]
  lyrics           SongLyrics?
  tab              SongTab?
  sequences        SongSequence[]
  evaluationRatings RehearsalSongRating[]
  concertEvaluationRatings ConcertSongRating[] @relation("ConcertSongRated")
}

model SongSequence {
  id          Int                 @id @default(autoincrement())
  songId      Int
  kind        SequenceKind        @default(AUDIO)
  title       String
  filePath    String              @db.Text
  fileSize    Int                 @default(0)
  channelMode SequenceChannelMode @default(STEREO)
  order       Int                 @default(0)
  createdById Int?
  createdAt   DateTime            @default(now())

  song      Song  @relation(fields: [songId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  loops     SequenceLoop[]
  scoreMarkers ScoreMarker[]

  @@index([songId])
}

// Boucles A–B sauvegardées par un membre sur une séquence (travail régulier).
model SequenceLoop {
  id         Int      @id @default(autoincrement())
  sequenceId Int
  userId     Int
  label      String?
  startSec   Float
  endSec     Float
  speed      Float    @default(1)
  createdAt  DateTime @default(now())

  sequence SongSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sequenceId, userId])
}

model SongLyrics {
  id        Int      @id @default(autoincrement())
  songId    Int      @unique
  content   String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model SongTab {
  id        Int      @id @default(autoincrement())
  songId    Int      @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  song Song @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model ChordChart {
  id            Int      @id @default(autoincrement())
  groupId       Int
  songId        Int?
  title         String
  tempo         String?
  keySignature  String?
  timeSignature String   @default("4/4")
  barsPerRow    Int      @default(4)
  totalBars     Int      @default(32)
  cells         Json
  sons          String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  song  Song?  @relation(fields: [songId], references: [id], onDelete: SetNull)
}

model GroupMemberHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  groupName String
  leftAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JoinRequest {
  id        Int               @id @default(autoincrement())
  userId    Int
  groupId   Int
  status    JoinRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model SiteSetting {
  key   String @id
  // TEXT et non VARCHAR(191) : certaines valeurs sont du JSON > 191 caractères
  // (home_zones, concertPopupLines…) qui sinon échouent à l'enregistrement sous MySQL.
  value String @db.Text
}

model PerfSnapshot {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  loadPercent    Int      @default(0)
  memPercent     Int      @default(0)
  diskPercent    Int      @default(0)
  dbPingMs       Int      @default(0)
  eventLoopLagMs Int      @default(0)

  @@index([createdAt])
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resource {
  id           Int          @id @default(autoincrement())
  songId       Int
  name         String
  type         ResourceType
  filePath     String
  fileSize     Int?
  uploadedById Int
  createdAt    DateTime     @default(now())

  song       Song @relation(fields: [songId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])
  scoreMarkers ScoreMarker[]
}

// Marqueurs audio 🔊 placés par un membre sur une partition (image/PDF), lançant un audio à un timecode.
model ScoreMarker {
  id         Int      @id @default(autoincrement())
  userId     Int
  resourceId Int
  sequenceId Int
  page       Int      @default(1)   // page PDF (1 pour une image)
  xPct       Float                  // position relative 0..1
  yPct       Float
  startSec   Float                  // timecode de départ dans l'audio
  label      String?
  createdAt  DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  sequence SongSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([resourceId, userId])
}

model PendingResource {
  id          Int          @id @default(autoincrement())
  songId      Int
  groupId     Int
  submittedBy Int
  name        String
  type        ResourceType
  filePath    String
  fileSize    Int?
  createdAt   DateTime     @default(now())

  song  Song  @relation(fields: [songId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [submittedBy], references: [id], onDelete: Cascade)
}

model ReminderLog {
  id          Int      @id @default(autoincrement())
  rehearsalId Int
  userId      Int
  sentById    Int
  sentAt      DateTime @default(now())

  rehearsal Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  user      User      @relation("RemindedUser", fields: [userId], references: [id], onDelete: Cascade)
  sentBy    User      @relation("ReminderSender", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([rehearsalId])
  @@index([userId])
}

model Annonce {
  id           Int           @id @default(autoincrement())
  title        String
  description  String        @db.Text
  category     String
  price        Float?
  location     String?
  photoPath    String?
  contactEmail String?
  contactPhone String?
  status       AnnonceStatus @default(PENDING)
  adminComment String?       @db.Text
  userId       Int
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expiresAt    DateTime

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([expiresAt])
}

// Module access control
model ModuleAccess {
  id        Int     @id @default(autoincrement())
  moduleKey String
  planKey   String
  enabled   Boolean @default(true)

  @@unique([moduleKey, planKey])
  @@index([moduleKey])
}

model ModuleUserOverride {
  id        Int     @id @default(autoincrement())
  moduleKey String
  userId    Int
  allowed   Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([moduleKey, userId])
  @@index([moduleKey])
}

model ModuleGroupOverride {
  id        Int     @id @default(autoincrement())
  moduleKey String
  groupId   Int
  allowed   Boolean

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([moduleKey, groupId])
  @@index([moduleKey])
}

model SupportTicket {
  id         Int            @id @default(autoincrement())
  userId     Int
  userName   String
  userEmail  String
  subject    String
  message    String         @db.Text
  category   TicketCategory @default(OTHER)
  status     TicketStatus   @default(OPEN)
  isPriority Boolean        @default(false)
  adminNote  String?        @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Tracks automatic 5-day reminders sent by cron (deduplicate per rehearsal+user)
model RehearsalAutoReminder {
  rehearsalId Int
  userId      Int
  sentAt      DateTime @default(now())

  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rehearsalId, userId])
  @@index([rehearsalId])
}

model CachetSimulation {
  id        Int      @id @default(autoincrement())
  userId    Int
  concertId Int?     // lié optionnellement à un concert
  label     String   // nom donné par l'utilisateur
  data      Json     // état complet du simulateur (sérialisé)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concert Concert? @relation(fields: [concertId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([concertId])
}

model Tutorial {
  id            Int      @id @default(autoincrement())
  title         String
  description   String?  @db.Text
  moduleKey     String?  // null = général; sinon clé de lib/modules.ts
  videoPath     String   // ex: /uploads/tutoriels/abc.mp4
  fileName      String
  fileSizeBytes Int
  order         Int      @default(0)
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GroupMessage {
  id        Int       @id @default(autoincrement())
  groupId   Int
  userId    Int
  content   String    @db.Text
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

// Slides du carrousel de la page d'accueil (gérés par l'admin)
model HomeSlide {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Newsletter (ouverte à tous, pas besoin d'être membre) ───
model NewsletterSubscriber {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  userId         Int?      // si lié à un compte
  token          String    @unique // pour la désinscription en 1 clic
  active         Boolean   @default(true)
  source         String?   // ex : 'site', 'profil', 'import'
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  receipts NewsletterRecipient[]

  @@index([active])
}

model Newsletter {
  id             Int       @id @default(autoincrement())
  subject        String
  content        String    @db.LongText // HTML
  status         String    @default("DRAFT") // DRAFT | SENT
  sentAt         DateTime?
  recipientCount Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  recipients NewsletterRecipient[]
}

// Trace de chaque destinataire ayant reçu une newsletter donnée.
// Permet de renvoyer la même news aux abonnés inscrits après l'envoi
// (ceux qui ne figurent pas encore dans cette table pour cette news).
model NewsletterRecipient {
  id           Int      @id @default(autoincrement())
  newsletterId Int
  subscriberId Int
  email        String   // snapshot de l'adresse au moment de l'envoi
  sentAt       DateTime @default(now())

  newsletter Newsletter           @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([newsletterId, subscriberId])
  @@index([newsletterId])
  @@index([subscriberId])
}

model HelpBubble {
  id        Int      @id @default(autoincrement())
  path      String              // pathname où la bulle s'affiche (correspondance exacte)
  xPct      Float               // repli : position horizontale en % de la largeur du contenu (0–100)
  yPx       Int                 // repli : position verticale en px depuis le haut du contenu
  // Ancrage à un élément visible (prioritaire sur xPct/yPx) : la bulle se place
  // relativement à cet élément, donc elle reste alignée quelles que soient les
  // différences de mise en page entre rôles/plans.
  anchorSelector String? @db.Text // sélecteur CSS de l'élément cible
  anchorDx       Float?           // position du marqueur dans l'élément (fraction de sa largeur, 0–1)
  anchorDy       Float?           // position du marqueur dans l'élément (fraction de sa hauteur, 0–1)
  title     String
  content   String   @db.Text
  emoji     String   @default("💡")
  color     String   @default("indigo") // indigo | amber | green | sky | rose | purple
  audience  String   @default("ALL")    // ALL | MEMBERS | CHEFS | ADMINS | USERS
  targetUserIds String? @db.Text        // JSON : ids des utilisateurs ciblés (audience USERS)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dismissals HelpBubbleDismissal[]

  @@index([path])
}

model HelpBubbleDismissal {
  id        Int      @id @default(autoincrement())
  bubbleId  Int
  userId    Int
  createdAt DateTime @default(now())

  bubble HelpBubble @relation(fields: [bubbleId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bubbleId, userId])
  @@index([bubbleId])
  @@index([userId])
}

// ─── Devoirs (mode École) : assignation privée prof → élève ───
enum AssignmentStatus {
  A_FAIRE
  EN_COURS
  FAIT
}

model Assignment {
  id          Int              @id @default(autoincrement())
  groupId     Int
  studentId   Int              // élève concerné
  teacherId   Int              // prof qui assigne
  title       String
  instruction String?          @db.Text
  songId      Int?             // morceau lié (optionnel)
  dueDate     DateTime?
  status      AssignmentStatus @default(A_FAIRE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation("AssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User  @relation("AssignmentTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  song    Song? @relation(fields: [songId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([studentId])
}

// Groupe de niveau (école) : un sous-ensemble nommé d'élèves, pour assigner un
// devoir à tout un niveau d'un coup. memberIds = JSON des userId.
model StudentLevelGroup {
  id        Int      @id @default(autoincrement())
  groupId   Int
  name      String
  memberIds String   @db.Text
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// Déduplication de la relance « dernière mise à jour du niveau de maîtrise »
// (envoyée la veille d'une répétition aux membres dont les morceaux ne sont pas
// tous à 100 %).
model MasteryReminderLog {
  rehearsalId Int
  userId      Int
  sentAt      DateTime @default(now())

  @@id([rehearsalId, userId])
}

// ─── Module « Tâches avant une date » ────────────────────────────────────────
// Listes de tâches à réaliser avant une date (répétition / concert / autre),
// assignées à un ou plusieurs membres, et envoyables par e-mail.
model TaskList {
  id          Int      @id @default(autoincrement())
  groupId     Int
  title       String
  dueDate     DateTime // date avant laquelle les tâches doivent être faites
  eventType   String   @default("other") // rehearsal | concert | other
  rehearsalId Int?     // référence indicative (pas de FK : la date est la source de vérité)
  concertId   Int?
  createdBy   Int?
  createdAt   DateTime @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([groupId])
}

model Task {
  id         Int       @id @default(autoincrement())
  taskListId Int
  label      String
  details    String?   @db.Text
  done       Boolean   @default(false)
  doneAt     DateTime?
  doneBy     Int?
  createdAt  DateTime  @default(now())

  list      TaskList       @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  assignees TaskAssignee[]

  @@index([taskListId])
}

model TaskAssignee {
  taskId Int
  userId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}
